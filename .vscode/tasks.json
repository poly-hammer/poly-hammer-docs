// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
        {
            "label": "Mkdocs Serve",
            "command": "uv run python scripts/sync_docs.py; uv run mkdocs serve --dev-addr localhost:8080",
            "type": "shell",
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        },
        {
            "label": "Mkdocs Build",
            "command": "uv run python scripts/sync_docs.py; uv run mkdocs build",
            "type": "shell",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "Pre-commit",
            "command": "uv run pre-commit run --all-files",
            "type": "shell",
            "group": {
                "kind": "test"
            }
        }
	],
    "inputs": []
}